<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vg_background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="?attr/actionModeCloseDrawable"
            android:contentDescription="Regresar" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Dispositivos"
            android:textColor="@color/vg_text_dark"
            android:textSize="18sp"

            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:id="@+id/dividerHeader"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/vg_border_light"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader" />

    <RelativeLayout
        android:id="@+id/layoutProgressInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"  app:layout_constraintTop_toBottomOf="@id/dividerHeader">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Progreso"
            android:textColor="@color/vg_text_dark"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="3 de 5 verificados"
            android:textColor="@color/vg_text_muted"
            android:textSize="12sp" />
    </RelativeLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        android:progress="60"
        android:progressTint="@color/vg_dark_blue"
        android:progressBackgroundTint="@color/vg_border_light"
        app:layout_constraintTop_toBottomOf="@id/layoutProgressInfo" />

    <LinearLayout
        android:id="@+id/layoutVerificationCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="24dp"
        android:background="@drawable/bg_login_card"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@+id/progressBar"
        app:layout_constraintBottom_toTopOf="@id/btnContinuar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verificación de conexión"
            android:textColor="@color/vg_text_muted"
            android:textSize="12sp"
            android:layout_gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MOCHILA UTL 1"
            android:textColor="@color/vg_text_dark"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/vg_border_light" />

        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="12dp">
            <ImageView android:id="@+id/imgStatus1" android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_check_green" android:layout_centerVertical="true"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_toEndOf="@id/imgStatus1" android:layout_marginStart="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Esp32" android:textColor="@color/vg_text_dark" android:textStyle="bold" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Señal Estable" android:textColor="@color/vg_text_muted" android:textSize="11sp"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:text="E" android:textColor="@color/vg_text_muted" android:textStyle="bold" />
        </RelativeLayout>

        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="12dp">
            <ImageView android:id="@+id/imgStatus2" android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_check_green" android:layout_centerVertical="true"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_toEndOf="@id/imgStatus2" android:layout_marginStart="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ultrasonico" android:textColor="@color/vg_text_dark" android:textStyle="bold" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Señal Estable" android:textColor="@color/vg_text_muted" android:textSize="11sp"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:text="E" android:textColor="@color/vg_text_muted" android:textStyle="bold" />
        </RelativeLayout>

        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="12dp">
            <ImageView android:id="@+id/imgStatus3" android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_check_green" android:layout_centerVertical="true"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_toEndOf="@id/imgStatus3" android:layout_marginStart="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Acelerometro" android:textColor="@color/vg_text_dark" android:textStyle="bold" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Señal Estable" android:textColor="@color/vg_text_muted" android:textSize="11sp"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:text="E" android:textColor="@color/vg_text_muted" android:textStyle="bold" />
        </RelativeLayout>

        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="12dp">
            <ImageView android:id="@+id/imgStatus4" android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_close_red" android:layout_centerVertical="true"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_toEndOf="@id/imgStatus4" android:layout_marginStart="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Conexión Wifi" android:textColor="@color/vg_text_dark" android:textStyle="bold" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="No responde" android:textColor="@color/vg_text_muted" android:textSize="11sp"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:text="NR" android:textColor="@color/vg_text_muted" android:textStyle="bold" />
        </RelativeLayout>

        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="12dp">
            <ImageView android:id="@+id/imgStatus5" android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_close_red" android:layout_centerVertical="true"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_toEndOf="@id/imgStatus5" android:layout_marginStart="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Motor de vibración" android:textColor="@color/vg_text_dark" android:textStyle="bold" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="No responde" android:textColor="@color/vg_text_muted" android:textSize="11sp"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:text="NR" android:textColor="@color/vg_text_muted" android:textStyle="bold" />
        </RelativeLayout>

    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnContinuar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/btn_primary"
        android:text="Continuar"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>